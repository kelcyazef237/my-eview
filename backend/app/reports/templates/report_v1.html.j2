<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>MYEVIEW — Cyber Trust Intelligence Report — {{ org.name }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600;8..60,700&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --ink:#0B1220;
    --ink-soft:#1C2438;
    --paper:#FAFAF7;
    --paper-alt:#F1EFE9;
    --hairline:#DEDACD;
    --slate:#5B6474;
    --slate-light:#8B90A0;
    --signal:#2B5F8A;
    --signal-light:#DCE8F0;
    --critical:#A83226;
    --critical-bg:#F7EBE9;
    --high:#9A5B14;
    --high-bg:#F8EFE3;
    --good:#3B7A57;
    --good-bg:#E9F2EC;
    --violet:#5B4B8A;
  }

  *{box-sizing:border-box; margin:0; padding:0;}

  body{
    background:var(--paper-alt);
    font-family:'Inter', sans-serif;
    color:var(--ink);
    -webkit-font-smoothing:antialiased;
  }

  .sheet{
    max-width:920px;
    margin:0 auto;
    background:var(--paper);
  }

  /* ===== MASTHEAD ===== */
  .masthead{
    background:var(--ink);
    color:var(--paper);
    padding:44px 56px 36px;
    position:relative;
    overflow:hidden;
  }
  .masthead::after{
    content:"";
    position:absolute;
    right:-60px; top:-60px;
    width:280px; height:280px;
    border:1px solid rgba(255,255,255,0.06);
    border-radius:50%;
  }
  .brand-row{
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
  }
  .brand{
    display:flex;
    align-items:center;
    gap:10px;
  }
  .brand-mark{
    width:26px; height:26px;
    border:1.5px solid var(--signal-light);
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    flex-shrink:0;
  }
  .brand-mark::before{
    content:"";
    width:9px; height:9px;
    background:var(--signal-light);
    border-radius:50%;
  }
  .brand-name{
    font-size:16px;
    letter-spacing:0.14em;
    font-weight:600;
  }
  .brand-name b{ font-weight:800; }
  .doc-type{
    text-align:right;
    font-size:11.5px;
    letter-spacing:0.12em;
    color:var(--slate-light);
    text-transform:uppercase;
  }
  .masthead-meta{
    margin-top:34px;
    padding-top:22px;
    border-top:1px solid rgba(255,255,255,0.12);
    display:flex;
    justify-content:space-between;
    align-items:flex-end;
  }
  .entity-name{
    font-family:'Source Serif 4', serif;
    font-size:32px;
    font-weight:500;
  }
  .entity-sub{
    font-size:14px;
    color:var(--slate-light);
    margin-top:5px;
  }
  .meta-tags{
    text-align:right;
    font-size:12.5px;
    color:var(--slate-light);
    line-height:1.8;
  }

  /* ===== SCORE PLATE ===== */
  .score-plate{
    padding:64px 56px 48px;
    text-align:center;
    border-bottom:1px solid var(--hairline);
  }
  .score-eyebrow{
    font-size:12px;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:var(--slate);
    font-weight:600;
  }
  .score-number{
    font-family:'Source Serif 4', serif;
    font-size:132px;
    line-height:1;
    font-weight:500;
    color:var(--ink);
    margin-top:14px;
    letter-spacing:-0.02em;
  }
  .score-number sup{
    font-size:34px;
    font-weight:400;
    color:var(--slate-light);
    top:-58px;
  }
  .score-bar-track{
    max-width:360px;
    margin:22px auto 0;
    height:4px;
    background:var(--hairline);
    border-radius:2px;
    position:relative;
  }
  .score-bar-fill{
    position:absolute;
    left:0; top:0; bottom:0;
    background:var(--signal);
    border-radius:2px;
  }
  .score-bar-labels{
    max-width:360px;
    margin:8px auto 0;
    display:flex;
    justify-content:space-between;
    font-size:11px;
    letter-spacing:0.1em;
    color:var(--slate-light);
  }

  .plate-row{
    margin-top:42px;
    display:flex;
    justify-content:center;
    gap:64px;
  }

  /* ===== SILVER SHIELD ROW ===== */
  .shield-row{
    display:flex;
    justify-content:center;
    align-items:flex-end;
    gap:10px;
    margin:28px auto 6px;
  }
  .tier-shield{
    width:72px;
    height:86px;
    display:block;
  }
  .shield-caption{
    text-align:center;
    font-size:13px;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--slate);
    font-weight:600;
    margin-top:8px;
  }
  .plate-stat{ text-align:center; }
  .plate-stat .num{
    font-family:'Source Serif 4', serif;
    font-size:34px;
    font-weight:500;
    color:var(--signal);
  }
  .plate-stat.is-text .num{
    font-family:'Inter', sans-serif;
    font-size:15px;
    font-weight:600;
    color:var(--ink-soft);
    line-height:1.35;
    max-width:220px;
  }
  .plate-stat .lbl{
    font-size:11.5px;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--slate);
    margin-top:7px;
  }
  .plate-divider{
    width:1px;
    background:var(--hairline);
  }

  .tier-badge{
    display:inline-flex;
    align-items:center;
    gap:8px;
    margin-top:34px;
    padding:9px 20px;
    border:1px solid var(--hairline);
    border-radius:30px;
    font-size:13px;
    letter-spacing:0.06em;
  }
  .tier-badge .roman{
    font-family:'Source Serif 4', serif;
    font-weight:600;
    color:var(--signal);
  }
  .tier-badge .dot{
    width:6px; height:6px;
    border-radius:50%;
  }
  .dot-good{ background:var(--good); }
  .dot-high{ background:var(--high); }
  .dot-critical{ background:var(--critical); }

  /* ===== SECTION SCAFFOLDING ===== */
  .section{
    padding:44px 56px;
    border-bottom:1px solid var(--hairline);
  }
  .section-label{
    font-size:12px;
    letter-spacing:0.16em;
    text-transform:uppercase;
    color:var(--slate);
    font-weight:600;
    margin-bottom:20px;
  }
  .section-label span{ color:var(--slate-light); font-weight:400; }

  .exec-summary p{
    font-family:'Source Serif 4', serif;
    font-size:19px;
    line-height:1.65;
    color:var(--ink-soft);
    max-width:760px;
  }

  /* ===== PERCENTILE ROW ===== */
  .percentiles{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:32px;
  }
  .percentile-card{
    background:var(--paper-alt);
    border:1px solid var(--hairline);
    border-radius:8px;
    padding:24px 26px;
  }
  .percentile-card .lbl{
    font-size:11.5px;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--slate);
  }
  .percentile-card .val{
    font-family:'Source Serif 4', serif;
    font-size:42px;
    color:var(--ink);
    margin-top:8px;
  }
  .percentile-card .val span{
    font-size:18px;
    color:var(--good);
    font-weight:600;
    vertical-align:2px;
    margin-right:4px;
  }
  .percentile-card .sub{
    font-size:13px;
    color:var(--slate);
    margin-top:5px;
  }
  .percentile-card .tag{
    display:inline-block;
    margin-top:12px;
    font-size:11px;
    letter-spacing:0.08em;
    color:var(--good);
    background:var(--good-bg);
    padding:4px 10px;
    border-radius:4px;
  }

  /* ===== RISK LEDGER ===== */
  .risk-item{
    padding:30px 0;
    border-top:1px solid var(--hairline);
  }
  .risk-item:first-child{ border-top:none; padding-top:0; }
  .risk-head{
    display:flex;
    align-items:baseline;
    gap:14px;
    margin-bottom:16px;
  }
  .risk-index{
    font-family:'Source Serif 4', serif;
    font-size:15px;
    color:var(--slate-light);
    min-width:20px;
  }
  .sev{
    font-size:10.5px;
    letter-spacing:0.09em;
    text-transform:uppercase;
    font-weight:700;
    padding:4px 10px;
    border-radius:4px;
  }
  .sev-critical{ color:var(--critical); background:var(--critical-bg); }
  .sev-high{ color:var(--high); background:var(--high-bg); }
  .sev-medium{ color:var(--signal); background:var(--signal-light); }
  .sev-low{ color:var(--slate); background:var(--paper-alt); }
  .risk-title{
    font-size:18.5px;
    font-weight:600;
  }

  .risk-body{ padding-left:34px; }
  .risk-body .obs{
    font-size:15px;
    color:var(--ink-soft);
    line-height:1.65;
    max-width:640px;
  }
  .risk-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:24px;
    margin-top:18px;
  }
  .risk-block .h{
    font-size:10.5px;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--slate);
    font-weight:600;
    margin-bottom:6px;
  }
  .risk-block p{
    font-size:14px;
    line-height:1.6;
    color:var(--slate);
  }
  .stakeholders{
    display:flex;
    flex-wrap:wrap;
    gap:6px;
    margin-top:6px;
  }
  .stakeholders span{
    font-size:11.5px;
    color:var(--ink-soft);
    background:var(--paper-alt);
    border:1px solid var(--hairline);
    padding:3px 9px;
    border-radius:20px;
  }
  .action-line{
    margin-top:16px;
    padding:14px 16px;
    background:var(--signal-light);
    border-left:2px solid var(--signal);
    border-radius:0 6px 6px 0;
    font-size:14px;
    color:var(--ink-soft);
    line-height:1.55;
  }
  .action-line b{ color:var(--signal); }

  /* ===== HYGIENE ===== */
  .hygiene-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:12px 32px;
  }
  .hygiene-item{
    display:flex;
    align-items:flex-start;
    gap:10px;
    padding:14px 0;
    border-bottom:1px solid var(--hairline);
  }
  .hygiene-item .mark{
    width:18px; height:18px;
    border-radius:50%;
    flex-shrink:0;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:11px;
    font-weight:700;
    margin-top:1px;
  }
  .mark-ok{ background:var(--good-bg); color:var(--good); }
  .mark-watch{ background:var(--high-bg); color:var(--high); }
  .mark-info{ background:var(--signal-light); color:var(--signal); }
  .hygiene-item .t{ font-size:14.5px; font-weight:600; }
  .hygiene-item .d{ font-size:13px; color:var(--slate); margin-top:2px; }

  /* ===== ENTITY INTELLIGENCE ===== */
  .entity-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:20px;
    margin-bottom:26px;
  }
  .entity-stat{
    text-align:center;
    padding:22px 10px;
    background:var(--paper-alt);
    border-radius:8px;
    border:1px solid var(--hairline);
  }
  .entity-stat .num{
    font-family:'Source Serif 4', serif;
    font-size:30px;
    color:var(--signal);
  }
  .entity-stat .lbl{
    font-size:11px;
    letter-spacing:0.05em;
    color:var(--slate);
    margin-top:8px;
    line-height:1.4;
  }
  .entity-note p{
    font-size:14.5px;
    line-height:1.7;
    color:var(--slate);
    max-width:680px;
  }
  .entity-note p + p{ margin-top:10px; }

  /* ===== REGULATORY ===== */
  .reg-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:24px;
  }
  .reg-card{
    padding:22px;
    border:1px solid var(--hairline);
    border-radius:8px;
  }
  .reg-card .code{
    font-size:11px;
    letter-spacing:0.1em;
    color:var(--signal);
    font-weight:700;
  }
  .reg-card .title{
    font-size:15px;
    font-weight:600;
    margin-top:6px;
    line-height:1.3;
  }
  .reg-card .body{
    font-size:13.5px;
    color:var(--slate);
    line-height:1.6;
    margin-top:10px;
  }
  .reg-disclaimer{
    font-size:12.5px;
    color:var(--slate-light);
    margin-top:22px;
    line-height:1.6;
    max-width:760px;
  }

  /* ===== CONCLUSION ===== */
  .conclusion{
    background:var(--ink);
    color:var(--paper);
    padding:56px;
  }
  .conclusion p{
    font-family:'Source Serif 4', serif;
    font-size:19px;
    line-height:1.7;
    color:#D7DCE5;
    max-width:720px;
  }

  /* ===== PROOF OF CONCEPT ===== */
  .poc-section{
    padding:44px 56px;
    background:#fdf6f4;
    border-top:1px solid #e8d5d0;
  }
  .poc-list{
    margin-top:18px;
    display:flex;
    flex-direction:column;
    gap:22px;
  }
  .poc-card{
    background:#fff;
    border:1px solid #e0d0cc;
    border-radius:8px;
    padding:22px 26px;
  }
  .poc-card .poc-head{
    display:flex;
    align-items:center;
    gap:10px;
    margin-bottom:10px;
  }
  .poc-card .poc-badge{
    display:inline-block;
    font-size:11px;
    font-weight:700;
    letter-spacing:0.08em;
    text-transform:uppercase;
    padding:3px 10px;
    border-radius:4px;
  }
  .poc-card .poc-badge.critical{ background:#c0392b; color:#fff; }
  .poc-card .poc-badge.high{ background:#e67e22; color:#fff; }
  .poc-card .poc-title{
    font-size:17px;
    font-weight:600;
    color:var(--ink);
  }
  .poc-card .poc-desc{
    font-size:14px;
    color:var(--slate);
    line-height:1.55;
    margin-bottom:12px;
  }
  .poc-card .poc-steps{
    background:#f8f5f4;
    border-left:3px solid #c0392b;
    padding:14px 18px;
    margin-bottom:10px;
    border-radius:0 4px 4px 0;
  }
  .poc-card .poc-steps .step{
    font-family:'Source Code Pro', monospace;
    font-size:13px;
    color:var(--ink);
    line-height:1.7;
    padding:2px 0;
  }
  .poc-card .poc-steps .step:before{
    content:"$ ";
    color:#999;
    font-weight:700;
  }
  .poc-card .poc-impact{
    font-size:13.5px;
    color:#c0392b;
    line-height:1.55;
    font-style:italic;
  }

  /* ===== SCAN QUALITY ===== */
  .scan-quality{
    padding:36px 56px;
    background:#f4f7fa;
    border-top:1px solid #d5e0ea;
  }
  .scan-quality .sq-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:20px;
    margin-top:16px;
  }
  .scan-quality .sq-item{
    background:#fff;
    border:1px solid #d5e0ea;
    border-radius:6px;
    padding:16px 20px;
  }
  .scan-quality .sq-item .sq-label{
    font-size:11px;
    font-weight:700;
    letter-spacing:0.10em;
    text-transform:uppercase;
    color:var(--slate-light);
    margin-bottom:6px;
  }
  .scan-quality .sq-item .sq-value{
    font-size:14px;
    color:var(--ink);
    line-height:1.6;
  }
  .scan-quality .sq-item .sq-value li{
    margin-bottom:4px;
    list-style:none;
    padding-left:14px;
    position:relative;
  }
  .scan-quality .sq-item .sq-value li:before{
    content:"▸ ";
    color:#aaa;
    position:absolute;
    left:0;
  }
  .scan-quality .confidence-badge{
    display:inline-block;
    font-size:12px;
    font-weight:700;
    padding:3px 12px;
    border-radius:4px;
    margin-top:8px;
  }
  .scan-quality .confidence-badge.high{ background:#27ae60; color:#fff; }
  .scan-quality .confidence-badge.medium{ background:#f39c12; color:#fff; }
  .scan-quality .confidence-badge.low{ background:#c0392b; color:#fff; }

  .conclusion-foot{
    margin-top:36px;
    padding-top:24px;
    border-top:1px solid rgba(255,255,255,0.12);
    display:flex;
    justify-content:space-between;
    align-items:center;
    font-size:12px;
    letter-spacing:0.06em;
    color:var(--slate-light);
    text-transform:uppercase;
  }
  .conclusion-foot .brand{ color:var(--paper); }

  .colophon{
    text-align:center;
    padding:26px;
    font-size:11.5px;
    letter-spacing:0.08em;
    color:var(--slate-light);
    text-transform:uppercase;
  }

  /* ===== PRINT =====
     Page 1 = cover (masthead + score plate). Analytical content starts on page 2.
     WeasyPrint does not run JS, so everything here is static HTML/CSS.
     The cover is compressed in print so the masthead + score-plate + shield
     all fit on a single page; without this the shield pushes content over
     and page-break-after leaves an empty page 2. */
  @media print{
    .masthead{ padding:32px 56px 28px; }
    .score-plate{ page-break-after:always; padding:36px 56px 32px; }
    .score-number{ font-size:104px; }
    .score-number sup{ font-size:28px; top:-46px; }
    .score-bar-track{ margin-top:16px; }
    .shield-row{ margin:16px auto 4px; gap:8px; }
    .tier-shield{ width:58px; height:70px; }
    .shield-caption{ font-size:11.5px; margin-top:4px; }
    .plate-row{ margin-top:26px; gap:52px; }
    .plate-stat .num{ font-size:28px; }
    .plate-stat.is-text .num{ font-size:13px; }
    .tier-badge{ margin-top:22px; padding:7px 18px; font-size:12px; }
    .section{ page-break-inside:avoid; }
    .sheet{ max-width:none; }
    .risk-item{ page-break-inside:avoid; }
  }

  @media (max-width:640px){
    .masthead, .section, .conclusion{ padding-left:24px; padding-right:24px; }
    .score-number{ font-size:84px; }
    .risk-grid, .percentiles, .entity-grid, .reg-grid{ grid-template-columns:1fr; }
    .risk-body{ padding-left:0; }
    .plate-row{ gap:32px; }
  }
</style>
</head>
<body>
<div class="sheet">

  <!-- MASTHEAD -->
  <div class="masthead">
    <div class="brand-row">
      <div class="brand">
        <div class="brand-mark"></div>
        <div class="brand-name">MY<b>EVIEW</b></div>
      </div>
      <div class="doc-type">Cyber Trust Intelligence Report</div>
    </div>
    <div class="masthead-meta">
      <div>
        <div class="entity-name">{{ org.name }}</div>
        <div class="entity-sub">{{ org.domain }} · Passive external assessment · Zero intrusion</div>
      </div>
      <div class="meta-tags">
        Assessment Date: {{ score.computed_at.strftime('%B %Y') if score.computed_at else '—' }}<br>
        Confidential · Single Use
      </div>
    </div>
  </div>

  <!-- SCORE PLATE -->
  <div class="score-plate">
    <div class="score-eyebrow">Myescore™ · Cyber Trust Index</div>
    <div class="score-number">{{ score.overall }}<sup>/ 1000</sup></div>
    <div class="score-bar-track"><div class="score-bar-fill" style="width:{{ (score.overall / 1000 * 100)|round(1) }}%"></div></div>
    <div class="score-bar-labels"><span>I</span><span>II</span><span>III</span><span>IV</span><span>V</span></div>

    {% set tier_colors = ['#A83226', '#9A5B14', '#2B5F8A', '#3B7A57', '#5B4B8A'] %}
    {% set tier_names = ['Critical', 'Elevated', 'Moderate', 'Strong', 'Exceptional'] %}
    {% set ti = (score.tier - 1) if score.tier else 2 %}
    {% set tier_color = tier_colors[ti] %}
    {% set tier_name = tier_names[ti] %}
    {% set shield_count = score.tier if score.tier else 1 %}
    <div class="shield-row" aria-label="{{ shield_count }} shield{{ '' if shield_count == 1 else 's' }} - {{ tier_name }} tier">
      {% for i in range(shield_count) %}
      <svg class="tier-shield" viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg" role="img">
        <defs>
          <linearGradient id="sb{{ loop.index }}" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#F5F7FA"/>
            <stop offset="32%" stop-color="#C9D2DC"/>
            <stop offset="52%" stop-color="#8B95A4"/>
            <stop offset="74%" stop-color="#D6DEE8"/>
            <stop offset="100%" stop-color="#6B7585"/>
          </linearGradient>
          <linearGradient id="ss{{ loop.index }}" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.55"/>
            <stop offset="48%" stop-color="#FFFFFF" stop-opacity="0.04"/>
            <stop offset="100%" stop-color="#000000" stop-opacity="0.18"/>
          </linearGradient>
          <linearGradient id="sr{{ loop.index }}" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#E9EEF4"/>
            <stop offset="50%" stop-color="#7B8595"/>
            <stop offset="100%" stop-color="#3C4654"/>
          </linearGradient>
        </defs>
        <!-- tier accent ring -->
        <path d="M50 3 L93 17 L93 60 Q93 93 50 117 Q7 93 7 60 L7 17 Z"
              fill="none" stroke="{{ tier_color }}" stroke-width="3.2" stroke-linejoin="round"/>
        <!-- silver body -->
        <path d="M50 7 L88.5 19.5 L88.5 60 Q88.5 90 50 112.5 Q11.5 90 11.5 60 L11.5 19.5 Z"
              fill="url(#sb{{ loop.index }})" stroke="url(#sr{{ loop.index }})" stroke-width="1.6" stroke-linejoin="round"/>
        <!-- shine overlay -->
        <path d="M50 7 L88.5 19.5 L88.5 60 Q88.5 90 50 112.5 Q11.5 90 11.5 60 L11.5 19.5 Z"
              fill="url(#ss{{ loop.index }})"/>
        <!-- inner highlight ridge -->
        <path d="M50 12 L84 22.5 L84 60 Q84 87 50 107.5 Q16 87 16 60 L16 22.5 Z"
              fill="none" stroke="#FFFFFF" stroke-width="0.6" stroke-opacity="0.35" stroke-linejoin="round"/>
        <!-- divider band -->
        <path d="M16 38 Q50 44 84 38" fill="none" stroke="{{ tier_color }}" stroke-width="0.8" stroke-opacity="0.55"/>
        <!-- tier-dependent damage: cracks on low tiers, pristine on high -->
        {% if score.tier == 1 %}
        <path d="M50 16 L45 30 L54 42 L47 56 L53 68 L48 82 L51 96" stroke="#1B1620" stroke-width="1.6" fill="none" opacity="0.72" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M47 42 L39 48 M53 56 L61 62 M48 68 L41 74 M52 82 L58 86" stroke="#1B1620" stroke-width="0.9" fill="none" opacity="0.5" stroke-linecap="round"/>
        <path d="M84 38 L79 44 L86 46 L82 50" stroke="#1B1620" stroke-width="0.8" fill="none" opacity="0.5" stroke-linecap="round"/>
        {% elif score.tier == 2 %}
        <path d="M50 22 L46 36 L53 50 L48 64 L51 80" stroke="#262030" stroke-width="1.2" fill="none" opacity="0.55" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M48 50 L41 56" stroke="#262030" stroke-width="0.8" fill="none" opacity="0.45" stroke-linecap="round"/>
        {% elif score.tier == 3 %}
        <path d="M84 44 L80 48 L85 50" stroke="#4A4452" stroke-width="0.7" fill="none" opacity="0.4" stroke-linecap="round"/>
        {% endif %}
        {% if score.tier == 5 %}
        <path d="M38 22 Q50 26 62 22" stroke="#FFFFFF" stroke-width="1" fill="none" opacity="0.55" stroke-linecap="round"/>
        <path d="M42 30 Q50 33 58 30" stroke="#FFFFFF" stroke-width="0.6" fill="none" opacity="0.35" stroke-linecap="round"/>
        {% endif %}
      </svg>
      {% endfor %}
    </div>
    <div class="shield-caption">{{ tier_name }} · {{ shield_count }} Shield{{ '' if shield_count == 1 else 's' }}</div>

    <div class="plate-row">
      <div class="plate-stat">
        <div class="num">{{ tier_name }}</div>
        <div class="lbl">Shield Tier</div>
      </div>
      <div class="plate-divider"></div>
      <div class="plate-stat is-text">
        <div class="num">{{ score.outlook }}</div>
        <div class="lbl">Trust Outlook</div>
      </div>
    </div>

    <div class="tier-badge">
      <span class="roman">{% if score.tier <= 2 %}Watch{% elif score.tier == 3 %}Monitor{% else %}Strong{% endif %}</span>
      <span class="dot {% if score.tier <= 2 %}dot-critical{% elif score.tier == 3 %}dot-high{% else %}dot-good{% endif %}"></span>
      <span style="color:var(--slate)">{% if score.tier <= 2 %}Monitoring recommended{% elif score.tier == 3 %}Periodic review{% else %}Maintain posture{% endif %}</span>
    </div>
  </div>

  <!-- EXECUTIVE SUMMARY -->
  <div class="section exec-summary">
    <div class="section-label">Executive Summary{% if is_ai_report %} <span>· AI-assessed</span>{% endif %}</div>
    {% if ai_executive_summary %}
    <p>{{ ai_executive_summary }}</p>
    {% else %}
    <p>{{ org.name }} ({{ org.domain }}) currently scores {{ score.overall }} of 1000, placing the institution at {{ score.shield_label }} with a trust outlook of {{ score.outlook }}. {% if risk_factors %}The assessment identified {{ risk_factors|length }} priority trust risk factor{{ 's' if risk_factors|length > 1 else '' }} requiring attention, primarily in {{ risk_factors[0].name }}{% if risk_factors|length > 1 %} and {{ risk_factors[1].name }}{% endif %}.{% else %}No priority risk factors were identified; the external posture reflects strong configuration hygiene across assessed vectors.{% endif %} Entity intelligence did not surface elevated-risk relationships or suspicious infrastructure associations during this assessment period.</p>
    {% endif %}
  </div>

  <!-- SECTOR POSITION -->
  <div class="section">
    <div class="section-label">Sector Position</div>
    <div class="percentiles">
      <div class="percentile-card">
        <div class="lbl">Sector Percentile</div>
        <div class="val"><span>&#9650;</span>{{ benchmarks.sector }}%</div>
        <div class="sub">Sector peer group</div>
        <div class="tag">Top {{ (100 - benchmarks.sector)|int }}% of assessed peers</div>
      </div>
      <div class="percentile-card">
        <div class="lbl">National Percentile</div>
        <div class="val"><span>&#9650;</span>{{ benchmarks.national }}%</div>
        <div class="sub">All assessed institutions — Cameroon</div>
        <div class="tag">Top {{ (100 - benchmarks.national)|int }}% nationally</div>
      </div>
    </div>
  </div>

  <!-- PRIORITY RISK FACTORS -->
  {% if risk_factors %}
  <div class="section">
    <div class="section-label">Priority Trust Risk Factors <span>· {{ risk_factors|length }} identified</span></div>

    {% for risk in risk_factors %}
    <div class="risk-item">
      <div class="risk-head">
        <span class="risk-index">{{ '%02d'|format(loop.index) }}</span>
        <span class="sev sev-{{ risk.severity }}">{{ risk.severity|capitalize }}</span>
        <span class="risk-title">{{ risk.name }}</span>
      </div>
      <div class="risk-body">
        {% if risk.tia.rendered_text and risk.tia.rendered_text.technical_observation %}
        <p class="obs">{{ risk.tia.rendered_text.technical_observation }}</p>
        {% else %}
        <p class="obs">Observation details unavailable for this risk factor.</p>
        {% endif %}

        {% if risk.tia.rendered_text %}
        <div class="risk-grid">
          <div class="risk-block">
            <div class="h">Business Impact</div>
            <p>{{ risk.tia.rendered_text.business_impact or '—' }}</p>
          </div>
          <div class="risk-block">
            <div class="h">Stakeholders Affected</div>
            {% if risk.tia.rendered_text.stakeholders_affected %}
            <div class="stakeholders">
              {% for s in risk.tia.rendered_text.stakeholders_affected %}
              <span>{{ s }}</span>
              {% endfor %}
            </div>
            {% else %}
            <p>—</p>
            {% endif %}
            <div class="h" style="margin-top:14px;">Regulatory Relevance</div>
            <p>{{ risk.tia.rendered_text.regulatory_relevance or '—' }}</p>
          </div>
        </div>
        <div class="action-line"><b>Recommended action —</b> {{ risk.tia.rendered_text.recommended_action or 'See technical observation above.' }}</div>
        {% endif %}
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- TRUST HYGIENE -->
  <div class="section">
    <div class="section-label">Trust Hygiene Observations</div>
    <div class="hygiene-grid">
      {% for item in hygiene %}
      <div class="hygiene-item">
        <div class="mark {% if item.status == 'ok' %}mark-ok{% elif item.status == 'warn' %}mark-watch{% else %}mark-info{% endif %}">
          {% if item.status == 'ok' %}&#10003;{% elif item.status == 'warn' %}!{% else %}&rarr;{% endif %}
        </div>
        <div><div class="t">{{ item.title }}</div><div class="d">{{ item.description }}</div></div>
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- ENTITY INTELLIGENCE -->
  <div class="section">
    <div class="section-label">Entity Intelligence</div>
    <div class="entity-grid">
      <div class="entity-stat"><div class="num">{{ entity_counts.associated_assets }}</div><div class="lbl">Associated Digital Assets Identified</div></div>
      <div class="entity-stat"><div class="num">{{ entity_counts.service_dependencies }}</div><div class="lbl">Externally Observable Service Dependencies</div></div>
      <div class="entity-stat"><div class="num">{{ entity_counts.risk_related_entities }}</div><div class="lbl">Elevated-Risk Related Entities Observed</div></div>
      <div class="entity-stat"><div class="num">{{ entity_counts.suspicious_relationships }}</div><div class="lbl">Suspicious Infrastructure Relationships</div></div>
    </div>
    <div class="entity-note">
      <p>Current observations suggest a {% if entity_counts.risk_related_entities + entity_counts.suspicious_relationships == 0 %}clean{% else %}mixed{% endif %} digital identity profile for {{ org.name }}, consistent with an institution of this size and operational model.</p>
      <p>Entity relationships often influence inherited risk, supplier exposure, and reputational association. Maintaining a clean entity profile is a meaningful positive signal as the institution's digital presence grows.</p>
    </div>
  </div>

  <!-- REGULATORY INTELLIGENCE -->
  <div class="section">
    <div class="section-label">Regulatory Intelligence Overview{% if org.sector and org.sector != 'general' %} — {{ org.sector_label }}{% endif %}</div>
    <div class="reg-grid">
      {% for reg in regulations %}
      <div class="reg-card">
        <div class="code">{{ reg.short }}</div>
        <div class="title">{{ reg.title }}</div>
        <div class="body">{{ reg.body }}</div>
      </div>
      {% endfor %}
    </div>
    <p class="reg-disclaimer">MYEVIEW identifies external exposure signals that may indicate areas warranting compliance review. This section does not constitute legal advice. All regulatory determinations should be made in consultation with qualified legal and compliance advisors.</p>
  </div>

  {% if is_ai_report and ai_proofs_of_concept %}
  <!-- PROOFS OF CONCEPT -->
  <div class="poc-section">
    <div class="section-label">Proofs of Concept <span style="color:var(--neon-red);font-size:12px">· AI-assessed</span></div>
    <p style="font-size:14px;color:var(--slate);margin-top:8px;max-width:760px;line-height:1.6">
      The following reproduction steps demonstrate how critical and high-severity findings can be
      verified or exploited. These are provided for authorized defensive testing only.
    </p>
    <div class="poc-list">
      {% for poc in ai_proofs_of_concept %}
      <div class="poc-card">
        <div class="poc-head">
          <span class="poc-badge {{ poc.severity }}">{{ poc.severity }}</span>
          <span class="poc-title">{{ poc.title }}</span>
        </div>
        <p class="poc-desc">{{ poc.description }}</p>
        <div class="poc-steps">
          {% for step in poc.steps %}
          <div class="step">{{ step }}</div>
          {% endfor %}
        </div>
        <p class="poc-impact"><strong>Impact:</strong> {{ poc.impact }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {% if is_ai_report and ai_scan_quality %}
  <!-- SCAN QUALITY NOTES -->
  <div class="scan-quality">
    <div class="section-label">Scan Quality Assessment <span style="color:var(--neon-violet);font-size:12px">· AI-assessed</span></div>
    <div class="sq-grid">
      <div class="sq-item">
        <div class="sq-label">Completeness</div>
        <div class="sq-value">{{ ai_scan_quality.completeness|capitalize }}</div>
        {% if ai_scan_quality.confidence %}
        <span class="confidence-badge {{ ai_scan_quality.confidence }}">Confidence: {{ ai_scan_quality.confidence }}</span>
        {% endif %}
      </div>
      {% if ai_scan_quality.missing_or_failed and ai_scan_quality.missing_or_failed|length > 0 %}
      <div class="sq-item">
        <div class="sq-label">Missing or Failed</div>
        <div class="sq-value">
          <ul>
            {% for item in ai_scan_quality.missing_or_failed %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
        </div>
      </div>
      {% endif %}
      {% if ai_scan_quality.coverage_gaps and ai_scan_quality.coverage_gaps|length > 0 %}
      <div class="sq-item">
        <div class="sq-label">Coverage Gaps</div>
        <div class="sq-value">
          <ul>
            {% for item in ai_scan_quality.coverage_gaps %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
        </div>
      </div>
      {% endif %}
    </div>
  </div>
  {% endif %}

  <!-- CONCLUSION -->
  <div class="conclusion">
    <div class="section-label" style="color:var(--slate-light)">Conclusion{% if is_ai_report %} <span style="color:var(--neon-violet);font-size:12px">· AI-assessed</span>{% endif %}</div>
    {% if ai_conclusion %}
    <p>{{ ai_conclusion }}</p>
    {% else %}
    <p>{{ org.name }} presents a {% if score.tier >= 4 %}strong{% else %}developing{% endif %} digital trust profile at {{ score.shield_label }}. {% if risk_factors %}The priority risk factors identified are addressable through configuration-level interventions that require no significant infrastructure investment, and their resolution would materially advance the institution's trust standing. {% endif %}The entity intelligence profile is {% if entity_counts.risk_related_entities + entity_counts.suspicious_relationships == 0 %}clean{% else %}largely clean{% endif %}, and the observable posture reflects an institution that takes its external digital responsibilities seriously. The Trust Outlook remains {{ score.outlook }}.</p>
    {% endif %}
    <div class="conclusion-foot">
      <div class="brand">Myeview</div>
      <div>Myescore™ {{ score.overall }} / 1000 · {{ score.shield_label }}</div>
    </div>
  </div>

  <div class="colophon">
    What does the internet expose about you? — myeview.com
  </div>

</div>
</body>
</html>