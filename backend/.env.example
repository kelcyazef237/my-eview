# MYEVIEW backend environment variables
# Copy this file to .env and adjust values for your deployment.

# Database
DATABASE_URL=postgresql://myeview:myeview@localhost:5432/myeview

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Application
APP_NAME=MYEVIEW
DEBUG=false
LOG_LEVEL=INFO

# CORS (comma-separated origins for the frontend)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Collectors
COLLECTOR_BIND_ADDRESS=0.0.0.0
COLLECTOR_TIMEOUT_SECONDS=10.0
COLLECTOR_MAX_RETRIES=3
COLLECTOR_RETRY_BACKOFF_SECONDS=2.0

# External threat-intel feeds
OTX_API_KEY=

# Scan cadence
DEFAULT_MONITORING_SCAN_DAYS=7
DEFAULT_FULL_REPORT_DAYS=30

# Public lookup rate limits
PUBLIC_LOOKUP_PER_DOMAIN_DAYS=30
PUBLIC_LOOKUP_PER_IP_MAX=20
PUBLIC_LOOKUP_PER_IP_WINDOW_SECONDS=3600

# Report URLs
REPORT_BASE_URL=http://localhost:8000
